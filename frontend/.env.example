# Optional: when the UI is not served through Vite’s dev proxy (e.g. static preview),
# point the browser at your FastAPI host. Use the public https URL from Railway → Networking
# (e.g. https://your-service.up.railway.app). Never use *.railway.internal in the browser.
# Leave unset in local dev with `npm run dev` (Vite proxy).
# VITE_API_URL=http://127.0.0.1:8000

# Firebase (client-safe config values). Put real values in frontend/.env.local
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
