rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uidField) {
      return signedIn() && resource.data[uidField] == request.auth.uid;
    }

    function isCreatingOwner(uidField) {
      return signedIn() && request.resource.data[uidField] == request.auth.uid;
    }

    function isTeamMember(teamId) {
      return signedIn()
        && exists(/databases/$(database)/documents/team_memberships/$(request.auth.uid + '_' + teamId));
    }

    // User private profile document: /users/{uid}
    match /users/{uid} {
      allow create, read, update, delete: if signedIn() && request.auth.uid == uid;
    }

    // Gameplans: owner-only writes/reads (team sharing can be relaxed later).
    match /gameplans/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }

    // Placeholder patterns for future migrations.
    match /opponents/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }
    match /diagrams/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }
    match /scouting_plays/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }
    match /scripts/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }
    match /script_entries/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }
    match /situation_plans/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }
    match /situation_calls/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }
    match /report_notes/{id} {
      allow create: if isCreatingOwner("owner_uid");
      allow read, update, delete: if isOwner("owner_uid");
    }

    // Teams (Postgres replacement): members can read; owner manages.
    match /teams/{teamId} {
      allow read: if signedIn()
        && (resource.data.owner_uid == request.auth.uid || isTeamMember(teamId));
      allow create: if isCreatingOwner("owner_uid");
      allow update, delete: if signedIn() && resource.data.owner_uid == request.auth.uid;
    }

    match /team_memberships/{membershipId} {
      allow read: if signedIn() && resource.data.user_uid == request.auth.uid;
      allow create: if signedIn()
        && request.resource.data.user_uid == request.auth.uid
        && membershipId == request.auth.uid + '_' + string(request.resource.data.team_id)
        && exists(/databases/$(database)/documents/teams/$(string(request.resource.data.team_id)));
      allow delete: if signedIn() && resource.data.user_uid == request.auth.uid;
      allow update: if false;
    }

    // Coaching chat persistence (Cloud Functions admin SDK only).
    match /coaching_sessions/{id} {
      allow read, write: if false;
    }
  }
}

